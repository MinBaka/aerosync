import "./font.ttf";
import { LineEdit, ScrollView } from "std-widgets.slint";

export struct FolderRow {
    id: string,
    title: string,
    subtitle: string,
    shared_text: string,
    status: string,
    paused: bool,
    completion_pct: float,
    need_bytes_text: string,
}

export struct DeviceRow {
    id: string,
    name: string,
    short_id: string,
    status: string,
    paused: bool,
    connected: bool,
    completion_pct: float,
    need_bytes_text: string,
}

export struct TransferRow {
    device_id: string,
    short_id: string,
    address: string,
    connection_type: string,
    status: string,
    connected: bool,
}

export struct LogRow {
    when: string,
    level: string,
    message: string,
}

export struct PendingDeviceRow {
    id: string,
    name: string,
    address: string,
}

export struct PendingFolderRow {
    id: string,
    label: string,
    offered_by: string,
}

component NavItem inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    height: 36px;
    border-radius: 8px;
    background: root.selected ? #eef2f7 : #ffffff00;

    animate background { duration: 200ms; easing: ease-in-out; }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 12px;

        Text {
            width: 16px;
            text: root.icon;
            color: root.selected ? #475569 : #94a3b8;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;

            animate color { duration: 200ms; easing: ease-in-out; }
        }

        Text {
            text: root.label;
            color: root.selected ? #111827 : #475569;
            font-size: 14px;
            font-weight: root.selected ? 700 : 500;
            vertical-alignment: center;

            animate color { duration: 200ms; easing: ease-in-out; }
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

component FlatButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();

    width: 76px;
    height: 36px;
    border-radius: 7px;
    border-width: root.primary ? 0px : 1px;
    border-color: root.danger ? #fecaca : #cbd5e1;
    background: !root.enabled ? #f1f5f9 : touch.pressed ? (root.primary ? #1d4ed8 : #f1f5f9) : touch.has-hover ? (root.primary ? #1e40af : #f8fafc) : root.primary ? #2563eb : #ffffff;

    animate background { duration: 150ms; easing: ease-in-out; }

    Text {
        text: root.text;
        color: !root.enabled ? #94a3b8 : root.primary ? #ffffff : root.danger ? #dc2626 : #1f2937;
        font-size: 14px;
        font-weight: root.primary ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            if root.enabled {
                root.clicked();
            }
        }
    }
}

component SmallButton inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();

    width: 58px;
    height: 32px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.danger ? #fecaca : #cbd5e1;
    background: !root.enabled ? #f8fafc : touch.pressed ? #f1f5f9 : touch.has-hover ? #f8fafc : #ffffff;

    animate background { duration: 150ms; easing: ease-in-out; }

    Text {
        text: root.text;
        color: !root.enabled ? #94a3b8 : root.danger ? #dc2626 : #334155;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            if root.enabled {
                root.clicked();
            }
        }
    }
}

component SummaryCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> detail;
    in property <bool> good: false;

    height: 116px;
    background: #ffffff;
    border-radius: 8px;
    border-width: 1px;
    border-color: #e5e7eb;

    VerticalLayout {
        padding: 14px;
        spacing: 4px;

        Text {
            text: root.label;
            color: #64748b;
            font-size: 13px;
        }

        Text {
            text: root.value;
            color: root.good ? #16a34a : #111827;
            font-size: 23px;
            font-weight: 800;
        }

        Text {
            text: root.detail;
            color: #94a3b8;
            font-size: 12px;
        }
    }
}

component Pill inherits Rectangle {
    in property <string> text;
    in property <bool> good: true;

    width: 56px;
    height: 28px;
    border-radius: 14px;
    border-width: 1px;
    border-color: root.good ? #bbf7d0 : #e2e8f0;
    background: root.good ? #dcfce7 : #f1f5f9;

    animate background { duration: 250ms; easing: ease-in-out; }
    animate border-color { duration: 250ms; easing: ease-in-out; }

    Text {
        text: root.text;
        color: root.good ? #15803d : #64748b;
        font-size: 12px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;

        animate color { duration: 250ms; easing: ease-in-out; }
    }
}

component Divider inherits Rectangle {
    height: 1px;
    background: #e5e7eb;
}

component OptionButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected: false;
    callback clicked();

    height: 36px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.selected ? #2563eb : #cbd5e1;
    background: root.selected ? #eff6ff : #ffffff;

    animate background { duration: 150ms; easing: ease-in-out; }
    animate border-color { duration: 150ms; easing: ease-in-out; }

    Text {
        text: root.text;
        color: root.selected ? #2563eb : #64748b;
        font-size: 13px;
        font-weight: root.selected ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;

        animate color { duration: 150ms; easing: ease-in-out; }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: "AeroSync";
    default-font-family: "HarmonyOS Sans SC";
    preferred-width: 1080px;
    preferred-height: 735px;
    min-width: 760px;
    min-height: 500px;
    background: #f3f6fb;

    in-out property <int> active_page: 0;
    in-out property <bool> is_loading: false;
    in-out property <bool> is_mutating: false;
    in-out property <bool> is_running: false;
    in-out property <bool> is_ready: false;
    in-out property <bool> restart_required: false;
    in-out property <bool> close_to_tray: false;
    in-out property <bool> is_downloading: false;
    in-out property <float> download_progress: 0.0;
    in-out property <bool> is_syncthing_downloaded: false;

    in-out property <string> status_text: "未连接";
    in-out property <string> last_updated: "尚未刷新";
    in-out property <string> success_message: "";
    in-out property <string> error_message: "";

    in-out property <string> folder_count_text: "0";
    in-out property <string> folder_detail_text: "0 个正在同步";
    in-out property <string> device_count_text: "0 / 0";
    in-out property <string> uptime_text: "等待数据";
    in-out property <string> traffic_text: "0 B ↓ / 0 B ↑";
    in-out property <string> api_endpoint: "127.0.0.1:58384";
    in-out property <string> local_device_id: "未知设备";
    in-out property <string> discovery_text: "等待数据";
    in-out property <string> start_time: "等待数据";
    in-out property <string> device_choices: "";
    in-out property <string> folder_choices: "";

    in property <[FolderRow]> folders;
    in property <[DeviceRow]> devices;
    in property <[TransferRow]> transfers;
    in property <[LogRow]> logs;
    in property <[PendingDeviceRow]> pending_devices;
    in property <[PendingFolderRow]> pending_folders;

    in-out property <bool> has_update: false;
    in-out property <string> latest_version: "";
    in-out property <bool> auto_upgrade_enabled: true;

    in-out property <bool> edit_folder_dialog: false;
    in-out property <bool> edit_device_dialog: false;
    in-out property <bool> ignores_dialog: false;
    in-out property <string> ignores_folder_id: "";
    in-out property <string> ignores_text: "";

    in-out property <bool> add_folder_dialog: false;
    in-out property <bool> add_device_dialog: false;
    in-out property <bool> global_settings_dialog: false;
    in-out property <bool> confirm_dialog: false;
    in-out property <string> confirm_title: "";
    in-out property <string> confirm_message: "";
    in-out property <string> confirm_action: "";
    in-out property <string> confirm_target: "";

    in-out property <string> folder_id: "";
    in-out property <string> folder_label: "";
    in-out property <string> folder_path: "";
    in-out property <string> folder_devices: "";
    in-out property <string> folder_type: "sendreceive";
    in-out property <int> folder_rescan_interval: 3600;
    in-out property <bool> folder_fs_watcher: true;
    in-out property <bool> folder_ignore_perms: false;
    in-out property <bool> folder_ignore_delete: false;
    in-out property <string> folder_versioning_type: "none";
    in-out property <string> folder_versioning_params: "";
    in-out property <string> device_id: "";
    in-out property <string> device_name: "";
    in-out property <string> device_addresses: "dynamic";
    in-out property <string> device_folders: "";
    in-out property <bool> device_introducer: false;
    in-out property <bool> device_auto_accept_folders: false;
    in-out property <string> device_compression: "metadata";

    in-out property <bool> global_discovery_enabled: true;
    in-out property <bool> local_discovery_enabled: true;
    in-out property <bool> global_announce_enabled: true;
    in-out property <bool> nat_enabled: true;
    in-out property <int> reconnection_interval: 60;
    in-out property <int> max_connections: 0;

    in-out property <string> config_max_recv_kbps: "";
    in-out property <string> config_max_send_kbps: "";

    callback refresh_requested();
    callback download_syncthing_requested();
    callback start_core_requested();
    callback shutdown_core_requested();
    callback restart_core_requested();
    callback set_rate_limits_requested(string, string);
    callback get_folder_ignores_requested(string);
    callback set_folder_ignores_requested(string, string);
    callback save_global_settings_requested();
    callback edit_folder_requested(string, string, string, string, string, int, bool, bool, bool, string);
    callback edit_device_requested(string, string, string, string, bool, bool, string);
    callback add_folder_requested(string, string, string, string, string, int, bool, bool, bool, string);
    callback add_device_requested(string, string, string, string, bool, bool, string);
    callback folder_action_requested(string, string);
    callback device_action_requested(string, string);
    callback global_action_requested(string);
    callback confirmed_action_requested(string, string);
    callback accept_device_requested(string);
    callback ignore_device_requested(string);
    callback accept_folder_requested(string, string, string);
    callback ignore_folder_requested(string, string);
    callback check_update_requested();
    callback upgrade_core_requested();
    callback toggle_auto_upgrade_requested(bool);

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            width: 220px;
            background: #ffffff;

            VerticalLayout {
                padding-top: 18px;
                padding-left: 10px;
                padding-right: 10px;
                padding-bottom: 16px;
                spacing: 16px;

                HorizontalLayout {
                    height: 54px;
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 12px;

                    Rectangle {
                        width: 34px;
                        height: 34px;
                        border-radius: 8px;
                        background: #111827;

                        Text {
                            text: "A";
                            color: #ffffff;
                            font-size: 20px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalLayout {
                        spacing: 1px;
                        Text {
                            text: "AeroSync";
                            color: #111827;
                            font-size: 17px;
                            font-weight: 800;
                        }
                        Text {
                            text: "同步管理";
                            color: #64748b;
                            font-size: 12px;
                        }
                    }
                }

                VerticalLayout {
                    spacing: 8px;
                    NavItem { icon: "↔"; label: "同步任务"; selected: root.active_page == 0; clicked => { root.active_page = 0; } }
                    NavItem { icon: "▣"; label: "设备管理"; selected: root.active_page == 1; clicked => { root.active_page = 1; } }
                    NavItem { icon: "◦"; label: "传输记录"; selected: root.active_page == 2; clicked => { root.active_page = 2; } }
                    NavItem { icon: "◈"; label: "日志"; selected: root.active_page == 3; clicked => { root.active_page = 3; } }
                    NavItem { icon: "⚙"; label: "设置"; selected: root.active_page == 4; clicked => { root.active_page = 4; } }
                }

                Rectangle { vertical-stretch: 1; }

                Divider { }

                HorizontalLayout {
                    height: 34px;
                    padding-left: 8px;
                    spacing: 9px;

                    Rectangle {
                        width: 8px;
                        height: 8px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 4px;
                        background: root.is_ready ? #22c55e : #94a3b8;
                    }

                    Text {
                        text: root.status_text;
                        color: #64748b;
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            width: 1px;
            background: #e5e7eb;
        }

        Rectangle {
            background: #f3f6fb;

            VerticalLayout {
                padding-top: 28px;
                padding-left: 16px;
                padding-right: 16px;
                padding-bottom: 22px;
                spacing: 16px;

                HorizontalLayout {
                    height: 66px;
                    spacing: 14px;

                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: root.active_page == 0 ? "同步任务" : root.active_page == 1 ? "设备管理" : root.active_page == 2 ? "传输记录" : root.active_page == 3 ? "日志" : "设置";
                            color: #111827;
                            font-size: 28px;
                            font-weight: 800;
                        }
                        Text {
                            text: root.active_page == 0 ? "管理本机同步文件夹和共享设备" : root.active_page == 1 ? "管理远程设备连接、暂停和删除" : root.active_page == 2 ? "查看当前连接和传输状态" : root.active_page == 3 ? "实时查看 Syncthing 运行日志" : "控制 Syncthing 核心和全局操作";
                            color: #64748b;
                            font-size: 14px;
                        }
                    }

                    Rectangle { }

                    FlatButton { width: 56px; text: root.is_loading ? "刷新中" : "刷新"; enabled: !root.is_loading && !root.is_mutating; clicked => { root.refresh_requested(); } }
                    FlatButton {
                        width: root.active_page == 4 ? 0px : root.active_page == 3 ? 0px : 124px;
                        visible: root.active_page == 0 || root.active_page == 1 || root.active_page == 2;
                        primary: root.active_page == 0 || root.active_page == 1;
                        text: root.active_page == 0 ? "添加同步任务" : root.active_page == 1 ? "添加设备" : "刷新连接";
                        enabled: !root.is_mutating && (root.active_page == 2 || root.is_ready);
                        clicked => {
                            if root.active_page == 0 {
                                root.folder_id = "";
                                root.folder_label = "";
                                root.folder_path = "";
                                root.folder_devices = root.device_choices;
                                root.add_folder_dialog = true;
                            } else if root.active_page == 1 {
                                root.device_id = "";
                                root.device_name = "";
                                root.device_addresses = "dynamic";
                                root.device_folders = root.folder_choices;
                                root.add_device_dialog = true;
                            } else {
                                root.refresh_requested();
                            }
                        }
                    }
                }

                HorizontalLayout {
                    height: 108px;
                    spacing: 12px;
                    SummaryCard { label: "核心状态"; value: root.status_text; detail: "最后刷新：" + root.last_updated; good: root.is_ready; }
                    SummaryCard { label: "同步文件夹"; value: root.folder_count_text; detail: root.folder_detail_text; }
                    SummaryCard { label: "连接设备"; value: root.device_count_text; detail: "运行时长：" + root.uptime_text; }
                    SummaryCard { label: "传输流量"; value: root.traffic_text; detail: "API：" + root.api_endpoint; }
                }

                Rectangle {
                    visible: root.restart_required || root.success_message != "" || root.error_message != "";
                    height: root.restart_required || root.success_message != "" || root.error_message != "" ? 40px : 0px;
                    background: root.error_message != "" ? #fff1f2 : root.restart_required ? #fffbeb : #f0fdf4;
                    border-color: root.error_message != "" ? #fecdd3 : root.restart_required ? #fde68a : #bbf7d0;
                    border-width: 1px;
                    border-radius: 8px;

                    Text {
                        x: 14px;
                        y: 0px;
                        width: parent.width - 28px;
                        height: parent.height;
                        vertical-alignment: center;
                        text: root.error_message != "" ? root.error_message : root.restart_required ? "Syncthing 提示需要重启核心才能完全应用配置。" : root.success_message;
                        color: root.error_message != "" ? #be123c : root.restart_required ? #92400e : #15803d;
                        font-size: 13px;
                    }
                }

                Rectangle {
                    background: #ffffff;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #e5e7eb;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 14px;

                        if root.active_page == 0 : Rectangle {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 14px;

                                if root.pending_folders.length > 0 : Rectangle {
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;
                                        Text { text: "待处理的文件夹共享请求"; color: #ea580c; font-size: 14px; font-weight: 700; }
                                        for pending in root.pending_folders : HorizontalLayout {
                                            spacing: 12px;
                                            VerticalLayout {
                                                spacing: 2px;
                                                Text { text: pending.label; color: #111827; font-size: 14px; font-weight: 600; }
                                                Text { text: "设备 " + pending.offered_by + " 想要共享文件夹 " + pending.id; color: #64748b; font-size: 12px; }
                                            }
                                            Rectangle { horizontal-stretch: 1; }
                                            FlatButton { width: 64px; text: "忽略"; clicked => { root.ignore_folder_requested(pending.id, pending.offered_by); } }
                                            FlatButton { width: 64px; primary: true; text: "接受"; clicked => { root.accept_folder_requested(pending.id, pending.offered_by, pending.label); } }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    height: 46px;
                                    spacing: 10px;

                                    VerticalLayout {
                                        spacing: 4px;
                                        Text { text: "同步文件夹"; color: #111827; font-size: 20px; font-weight: 800; }
                                        Text { text: "当前已配置的同步目录"; color: #64748b; font-size: 13px; }
                                    }

                                    Rectangle { }

                                    FlatButton { width: 86px; text: "扫描全部"; enabled: root.is_ready && !root.is_mutating; clicked => { root.global_action_requested("rescan-all"); } }
                                }

                                HorizontalLayout {
                                    height: 27px;
                                    padding-left: 0px;
                                    spacing: 0px;
                                    Text { horizontal-stretch: 1; text: "名称"; color: #64748b; font-size: 13px; }
                                    Text { width: 110px; text: "共享设备"; color: #64748b; font-size: 13px; }
                                    Text { width: 110px; text: "状态"; color: #64748b; font-size: 13px; }
                                    Text { width: 326px; text: "操作"; color: #64748b; font-size: 13px; }
                                    Rectangle { width: 14px; }
                                }
                                Divider { }

                                ScrollView {
                                    VerticalLayout {
                                        spacing: 0px;
                                        for folder in root.folders : Rectangle {
                                            height: 72px;
                                            background: #ffffff;

                                            HorizontalLayout {
                                                spacing: 0px;

                                                VerticalLayout {
                                                    horizontal-stretch: 1;
                                                    padding-top: 11px;
                                                    spacing: 5px;
                                                    HorizontalLayout {
                                                        spacing: 8px;
                                                        Text { text: folder.title; color: #1f2937; font-size: 15px; font-weight: 800; overflow: elide; }
                                                        if folder.completion_pct < 1.0 : Text { text: round(folder.completion_pct * 100) + "%"; color: #2563eb; font-size: 13px; font-weight: 800; vertical-alignment: bottom; }
                                                    }
                                                    HorizontalLayout {
                                                        spacing: 8px;
                                                        Text { text: folder.subtitle; color: #64748b; font-size: 13px; overflow: elide; }
                                                        if folder.need_bytes_text != "" : Text { text: folder.need_bytes_text; color: #f59e0b; font-size: 12px; }
                                                    }
                                                }

                                                Text { width: 110px; text: folder.shared_text; color: #475569; font-size: 14px; vertical-alignment: center; }

                                                Rectangle {
                                                    width: 110px;
                                                    Pill { y: 22px; text: folder.status; good: !folder.paused; }
                                                }

                                                HorizontalLayout {
                                                    width: 326px;
                                                    spacing: 7px;
                                                    padding-top: 19px;
                                                    padding-right: 14px;
                                                    SmallButton { text: "扫描"; enabled: root.is_ready && !root.is_mutating; clicked => { root.folder_action_requested("rescan", folder.id); } }
                                                    SmallButton { text: "忽略"; enabled: root.is_ready && !root.is_mutating; clicked => { root.ignores_folder_id = folder.id; root.ignores_text = ""; root.get_folder_ignores_requested(folder.id); root.ignores_dialog = true; } }
                                                    SmallButton { text: "编辑"; enabled: root.is_ready && !root.is_mutating; clicked => { root.folder_id = folder.id; root.folder_label = folder.title; root.folder_path = folder.subtitle; root.folder_devices = ""; root.edit_folder_dialog = true; } }
                                                    SmallButton { text: folder.paused ? "恢复" : "暂停"; enabled: root.is_ready && !root.is_mutating; clicked => { root.folder_action_requested(folder.paused ? "resume" : "pause", folder.id); } }
                                                    SmallButton { text: "删除"; danger: true; enabled: root.is_ready && !root.is_mutating; clicked => { root.confirm_title = "删除同步文件夹"; root.confirm_message = "确认从 Syncthing 配置中删除这个文件夹？本操作不会删除磁盘上的实际文件。"; root.confirm_action = "remove-folder"; root.confirm_target = folder.id; root.confirm_dialog = true; } }
                                                    SmallButton { text: "删文件"; danger: true; enabled: root.is_ready && !root.is_mutating; clicked => { root.confirm_title = "删除文件夹文件"; root.confirm_message = "警告：此操作将删除磁盘上的实际文件夹及其所有内容，无法恢复！"; root.confirm_action = "delete-folder-files"; root.confirm_target = folder.id; root.confirm_dialog = true; } }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if root.active_page == 1 : Rectangle {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 14px;

                                if root.pending_devices.length > 0 : Rectangle {
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;
                                        Text { text: "待处理的设备连接请求"; color: #ea580c; font-size: 14px; font-weight: 700; }
                                        for pending in root.pending_devices : HorizontalLayout {
                                            spacing: 12px;
                                            VerticalLayout {
                                                spacing: 2px;
                                                Text { text: pending.name != "" ? pending.name : "未知设备"; color: #111827; font-size: 14px; font-weight: 600; }
                                                Text { text: "设备 " + pending.id + " (" + pending.address + ") 请求连接"; color: #64748b; font-size: 12px; }
                                            }
                                            Rectangle { horizontal-stretch: 1; }
                                            FlatButton { width: 64px; text: "拒绝"; clicked => { root.ignore_device_requested(pending.id); } }
                                            FlatButton { width: 64px; primary: true; text: "接受"; clicked => { root.accept_device_requested(pending.id); } }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    height: 46px;
                                    spacing: 10px;
                                    VerticalLayout {
                                        spacing: 4px;
                                        Text { text: "设备管理"; color: #111827; font-size: 20px; font-weight: 800; }
                                        Text { text: "远程设备连接状态"; color: #64748b; font-size: 13px; }
                                    }

                                    Rectangle { }
                                }

                                HorizontalLayout {
                                    height: 27px;
                                    spacing: 0px;
                                    Text { horizontal-stretch: 1; text: "名称"; color: #64748b; font-size: 13px; }
                                    Text { width: 110px; text: "状态"; color: #64748b; font-size: 13px; }
                                    Text { width: 194px; text: "操作"; color: #64748b; font-size: 13px; }
                                    Rectangle { width: 14px; }
                                }
                                Divider { }

                                ScrollView {
                                    VerticalLayout {
                                        spacing: 0px;
                                        for device in root.devices : Rectangle {
                                            height: 72px;
                                            background: #ffffff;
                                            HorizontalLayout {
                                                spacing: 0px;
                                                VerticalLayout {
                                                    horizontal-stretch: 1;
                                                    padding-top: 11px;
                                                    spacing: 5px;
                                                    HorizontalLayout {
                                                        spacing: 8px;
                                                        Text { text: device.name; color: #1f2937; font-size: 15px; font-weight: 800; overflow: elide; }
                                                        if device.completion_pct < 1.0 : Text { text: round(device.completion_pct * 100) + "%"; color: #2563eb; font-size: 13px; font-weight: 800; vertical-alignment: bottom; }
                                                    }
                                                    HorizontalLayout {
                                                        spacing: 8px;
                                                        Text { text: device.short_id; color: #64748b; font-size: 13px; overflow: elide; }
                                                        if device.need_bytes_text != "" : Text { text: device.need_bytes_text; color: #f59e0b; font-size: 12px; }
                                                    }
                                                }
                                                Rectangle { width: 110px; Pill { y: 22px; text: device.status; good: device.connected && !device.paused; } }
                                                HorizontalLayout {
                                                    width: 194px;
                                                    spacing: 8px;
                                                    padding-top: 19px;
                                                    padding-right: 14px;
                                                    SmallButton { text: "编辑"; enabled: root.is_ready && !root.is_mutating; clicked => { root.device_id = device.id; root.device_name = device.name; root.device_addresses = ""; root.device_folders = ""; root.edit_device_dialog = true; } }
                                                    SmallButton { text: device.paused ? "恢复" : "暂停"; enabled: root.is_ready && !root.is_mutating; clicked => { root.device_action_requested(device.paused ? "resume" : "pause", device.id); } }
                                                    SmallButton { text: "删除"; danger: true; enabled: root.is_ready && !root.is_mutating; clicked => { root.confirm_title = "删除远程设备"; root.confirm_message = "确认删除该设备？它也会从所有共享文件夹中移除。"; root.confirm_action = "remove-device"; root.confirm_target = device.id; root.confirm_dialog = true; } }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if root.active_page == 2 : Rectangle {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 14px;

                                HorizontalLayout {
                                    height: 46px;
                                    spacing: 10px;
                                    VerticalLayout {
                                        spacing: 4px;
                                        Text { text: "传输记录"; color: #111827; font-size: 20px; font-weight: 800; }
                                        Text { text: "当前 Syncthing 连接和流量概览"; color: #64748b; font-size: 13px; }
                                    }

                                    Rectangle { }

                                    FlatButton { width: 56px; text: "刷新"; enabled: !root.is_loading && !root.is_mutating; clicked => { root.refresh_requested(); } }
                                }

                                HorizontalLayout {
                                    height: 27px;
                                    spacing: 0px;
                                    Text { horizontal-stretch: 1; text: "设备"; color: #64748b; font-size: 13px; }
                                    Text { horizontal-stretch: 1; text: "地址"; color: #64748b; font-size: 13px; }
                                    Text { width: 120px; text: "类型"; color: #64748b; font-size: 13px; }
                                    Text { width: 104px; text: "状态"; color: #64748b; font-size: 13px; }
                                    Rectangle { width: 14px; }
                                }
                                Divider { }

                                ScrollView {
                                    VerticalLayout {
                                        spacing: 0px;
                                        for transfer in root.transfers : Rectangle {
                                            height: 72px;
                                            background: #ffffff;
                                            HorizontalLayout {
                                                spacing: 0px;
                                                VerticalLayout { horizontal-stretch: 1; padding-top: 11px; spacing: 5px; Text { text: transfer.short_id; color: #1f2937; font-size: 15px; font-weight: 800; overflow: elide; } Text { text: transfer.device_id; color: #64748b; font-size: 12px; overflow: elide; } }
                                                Text { horizontal-stretch: 1; text: transfer.address; color: #475569; font-size: 13px; vertical-alignment: center; overflow: elide; }
                                                Text { width: 120px; text: transfer.connection_type; color: #475569; font-size: 13px; vertical-alignment: center; }
                                                Rectangle { width: 104px; Pill { y: 22px; text: transfer.status; good: transfer.connected; } }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if root.active_page == 3 : Rectangle {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 14px;

                                HorizontalLayout {
                                    height: 46px;
                                    spacing: 10px;
                                    VerticalLayout {
                                        spacing: 4px;
                                        Text { text: "日志"; color: #111827; font-size: 20px; font-weight: 800; }
                                        Text { text: "Syncthing 核心实时日志"; color: #64748b; font-size: 13px; }
                                    }

                                    Rectangle { }

                                    FlatButton { width: 56px; text: "刷新"; enabled: !root.is_loading && !root.is_mutating; clicked => { root.refresh_requested(); } }
                                }

                                HorizontalLayout {
                                    height: 27px;
                                    spacing: 0px;
                                    Text { width: 140px; text: "时间"; color: #64748b; font-size: 13px; }
                                    Text { width: 80px; text: "级别"; color: #64748b; font-size: 13px; }
                                    Text { horizontal-stretch: 1; text: "消息"; color: #64748b; font-size: 13px; }
                                    Rectangle { width: 14px; }
                                }
                                Divider { }

                                ScrollView {
                                    VerticalLayout {
                                        padding-right: 14px;
                                        spacing: 0px;
                                        for log in root.logs : Rectangle {
                                            min-height: 52px;
                                            background: #ffffff;
                                            HorizontalLayout {
                                                padding-top: 11px;
                                                padding-bottom: 11px;
                                                padding-right: 8px;
                                                spacing: 0px;
                                                Text { width: 140px; text: log.when; color: #64748b; font-size: 12px; vertical-alignment: top; overflow: elide; }
                                                Rectangle {
                                                    width: 80px;
                                                    VerticalLayout {
                                                        Pill {
                                                            text: log.level;
                                                            good: log.level == "INFO";
                                                        }
                                                    }
                                                }
                                                Text {
                                                    horizontal-stretch: 1;
                                                    text: log.message;
                                                    color: #1f2937;
                                                    font-size: 13px;
                                                    vertical-alignment: top;
                                                    wrap: word-wrap;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if root.active_page == 4 : ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                padding-right: 14px;
                                spacing: 16px;

                                HorizontalLayout {
                                    height: 46px;
                                    spacing: 10px;
                                    VerticalLayout {
                                        spacing: 4px;
                                        Text { text: "设置"; color: #111827; font-size: 20px; font-weight: 800; }
                                        Text { text: "控制 Syncthing 核心和全局同步状态"; color: #64748b; font-size: 13px; overflow: elide; }
                                    }

                                    Rectangle { }
                                }

                                Rectangle {
                                    height: 100px;
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;

                                        HorizontalLayout {
                                            height: 36px;
                                            spacing: 12px;
                                            Text { width: 92px; text: "核心更新"; color: #111827; font-size: 16px; font-weight: 800; vertical-alignment: center; }
                                            Text { horizontal-stretch: 1; text: !root.is_syncthing_downloaded ? "等待下载核心" : root.has_update ? "发现新版本：" + root.latest_version : "当前已是最新版本"; color: !root.is_syncthing_downloaded ? #94a3b8 : root.has_update ? #ea580c : #64748b; font-size: 13px; vertical-alignment: center; overflow: elide; }
                                        }

                                        if root.is_syncthing_downloaded : HorizontalLayout {
                                            height: 44px;
                                            spacing: 12px;
                                            FlatButton { width: 104px; primary: !root.has_update; text: "检查更新"; enabled: root.is_ready && !root.is_mutating; clicked => { root.check_update_requested(); } }
                                            if root.has_update : FlatButton { width: 104px; primary: true; text: "立即更新"; enabled: root.is_ready && !root.is_mutating; clicked => { root.upgrade_core_requested(); } }
                                            Rectangle { horizontal-stretch: 1; }
                                            HorizontalLayout {
                                                spacing: 8px;
                                                Text { text: "自动更新"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                                                Rectangle {
                                                    width: 44px; height: 24px; border-radius: 12px; y: (parent.height - self.height) / 2;
                                                    background: root.auto_upgrade_enabled ? #2563eb : #cbd5e1;
                                                    animate background { duration: 200ms; easing: ease-in-out; }
                                                    Rectangle {
                                                        width: 20px; height: 20px; border-radius: 10px;
                                                        background: #ffffff;
                                                        x: root.auto_upgrade_enabled ? 22px : 2px;
                                                        y: 2px;
                                                        animate x { duration: 200ms; easing: ease-in-out; }
                                                    }
                                                    TouchArea { clicked => { root.auto_upgrade_enabled = !root.auto_upgrade_enabled; root.toggle_auto_upgrade_requested(root.auto_upgrade_enabled); } }
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 136px;
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;

                                        HorizontalLayout {
                                            height: 36px;
                                            spacing: 12px;
                                            Text { width: 92px; text: "核心控制"; color: #111827; font-size: 16px; font-weight: 800; vertical-alignment: center; }
                                            Text { horizontal-stretch: 1; text: !root.is_syncthing_downloaded ? "Syncthing 核心尚未下载，请先下载。" : root.is_running ? "当前核心正在运行，可以停止或重启。" : "当前核心未运行，请先启动核心。"; color: #64748b; font-size: 13px; vertical-alignment: center; overflow: elide; }
                                        }

                                        if !root.is_syncthing_downloaded : HorizontalLayout {
                                            height: 44px;
                                            spacing: 12px;
                                            FlatButton { width: 124px; primary: true; text: "下载 Syncthing"; enabled: !root.is_downloading; clicked => { root.download_syncthing_requested(); } }
                                            if root.is_downloading : Rectangle {
                                                height: 36px;
                                                vertical-stretch: 1;
                                                HorizontalLayout {
                                                    spacing: 12px;
                                                    Rectangle { width: 200px; height: 8px; border-radius: 4px; background: #e2e8f0; Rectangle { x: 0; width: parent.width * root.download_progress; height: 100%; border-radius: 4px; background: #2563eb; } }
                                                    Text { text: round(root.download_progress * 100) + "%"; color: #64748b; font-size: 12px; vertical-alignment: center; }
                                                }
                                            }
                                            Rectangle { }
                                        }

                                        if root.is_syncthing_downloaded : HorizontalLayout {
                                            height: 44px;
                                            spacing: 12px;
                                            if !root.is_running : FlatButton {
                                                width: 104px;
                                                primary: true;
                                                text: "启动核心";
                                                enabled: !root.is_mutating;
                                                clicked => { root.start_core_requested(); }
                                            }
                                            if root.is_running : FlatButton {
                                                width: 104px;
                                                danger: true;
                                                text: "停止核心";
                                                enabled: !root.is_mutating;
                                                clicked => { root.shutdown_core_requested(); }
                                            }
                                            if root.is_running : FlatButton {
                                                width: 104px;
                                                text: "重启核心";
                                                enabled: !root.is_mutating;
                                                clicked => { root.restart_core_requested(); }
                                            }
                                            Rectangle { }
                                        }

                                        Text { horizontal-stretch: 1; text: root.is_mutating ? "正在执行操作，请稍候。" : "这些按钮会直接启动、停止或重启本机 Syncthing 核心。"; color: #94a3b8; font-size: 12px; overflow: elide; }
                                    }
                                }

                                Rectangle {
                                    height: 202px;
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;

                                        HorizontalLayout {
                                            height: 46px;
                                            spacing: 12px;
                                            Text { width: 104px; text: "网络限速"; color: #111827; font-size: 16px; font-weight: 800; vertical-alignment: center; }
                                            VerticalLayout {
                                                vertical-stretch: 1;
                                                padding-top: 5px;
                                                padding-bottom: 5px;
                                                LineEdit { placeholder-text: "接收限制 (Kbps)，0 为不限"; text <=> root.config_max_recv_kbps; }
                                            }
                                            VerticalLayout {
                                                vertical-stretch: 1;
                                                padding-top: 5px;
                                                padding-bottom: 5px;
                                                LineEdit { placeholder-text: "发送限制 (Kbps)，0 为不限"; text <=> root.config_max_send_kbps; }
                                            }
                                            VerticalLayout {
                                                padding-top: 5px;
                                                padding-bottom: 5px;
                                                FlatButton { width: 80px; text: "应用"; enabled: root.is_ready && !root.is_mutating; clicked => { root.set_rate_limits_requested(root.config_max_recv_kbps, root.config_max_send_kbps); } }
                                            }
                                        }

                                        HorizontalLayout {
                                            height: 36px;
                                            spacing: 12px;
                                            Text { width: 104px; text: "全局设备操作"; color: #111827; font-size: 16px; font-weight: 800; vertical-alignment: center; }
                                            Text { horizontal-stretch: 1; text: "一次性暂停或恢复所有远程设备。"; color: #64748b; font-size: 13px; vertical-alignment: center; overflow: elide; }
                                        }

                                        HorizontalLayout {
                                            height: 44px;
                                            spacing: 12px;
                                            FlatButton { width: 128px; text: "暂停全部设备"; enabled: root.is_ready && !root.is_mutating; clicked => { root.global_action_requested("pause-all"); } }
                                            FlatButton { width: 128px; text: "恢复全部设备"; enabled: root.is_ready && !root.is_mutating; clicked => { root.global_action_requested("resume-all"); } }
                                            Rectangle { }
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 80px;
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    HorizontalLayout {
                                        padding: 12px;
                                        spacing: 12px;
                                        VerticalLayout {
                                            spacing: 4px;
                                            Text { text: "全局高级设置"; color: #111827; font-size: 16px; font-weight: 800; vertical-alignment: center; }
                                            Text { text: "配置发现、NAT 穿透、连接等高级选项"; color: #64748b; font-size: 12px; }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                        FlatButton {
                                            width: 104px;
                                            text: "打开设置";
                                            enabled: root.is_ready && !root.is_mutating;
                                            clicked => { root.global_settings_dialog = true; }
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 80px;
                                    background: #f8fafc;
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    HorizontalLayout {
                                        padding: 12px;
                                        spacing: 12px;
                                        VerticalLayout {
                                            spacing: 4px;
                                            Text { text: "最小化到托盘"; color: #111827; font-size: 16px; font-weight: 800; vertical-alignment: center; }
                                            Text { text: "关闭窗口时最小化到系统托盘而不是退出程序"; color: #64748b; font-size: 12px; }
                                        }
                                        Rectangle { horizontal-stretch: 1; }
                                        Rectangle {
                                            width: 44px; height: 24px; border-radius: 12px;
                                            background: root.close_to_tray ? #2563eb : #cbd5e1;

                                            animate background { duration: 200ms; easing: ease-in-out; }

                                            Rectangle {
                                                width: 20px; height: 20px; border-radius: 10px;
                                                background: #ffffff;
                                                x: root.close_to_tray ? 22px : 2px;
                                                y: 2px;

                                                animate x { duration: 200ms; easing: ease-in-out; }
                                            }
                                            TouchArea { clicked => { root.close_to_tray = !root.close_to_tray; } }
                                        }
                                    }
                                }

                                Divider { }
                                Text { text: "本机设备 ID：" + root.local_device_id; color: #1f2937; font-size: 14px; overflow: elide; }
                                Text { text: "发现服务：" + root.discovery_text; color: #1f2937; font-size: 14px; overflow: elide; }
                                Text { text: "启动时间：" + root.start_time; color: #1f2937; font-size: 14px; overflow: elide; }
                                Text { text: "API 端点：" + root.api_endpoint; color: #1f2937; font-size: 14px; overflow: elide; }
                                Rectangle { vertical-stretch: 1; }
                            }
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.add_folder_dialog || root.edit_folder_dialog || root.add_device_dialog || root.edit_device_dialog || root.global_settings_dialog || root.ignores_dialog || root.confirm_dialog;
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: #00000066;
        opacity: root.add_folder_dialog || root.edit_folder_dialog || root.add_device_dialog || root.edit_device_dialog || root.global_settings_dialog || root.ignores_dialog || root.confirm_dialog ? 1.0 : 0.0;

        animate opacity { duration: 200ms; easing: ease-in-out; }
    }

    Rectangle {
        visible: root.add_folder_dialog || root.edit_folder_dialog;
        x: (root.width - 600px) / 2;
        y: 60px;
        width: 600px;
        height: 620px;
        background: #ffffff;
        border-radius: 12px;
        opacity: root.add_folder_dialog || root.edit_folder_dialog ? 1.0 : 0.0;

        animate opacity { duration: 200ms; easing: ease-out; }
        animate y { duration: 250ms; easing: ease-out; }

        VerticalLayout {
            padding: 22px;
            spacing: 12px;
            Text { text: root.edit_folder_dialog ? "编辑同步文件夹" : "添加同步文件夹"; color: #111827; font-size: 21px; font-weight: 800; }

            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    padding-right: 12px;
                    spacing: 12px;

                    Text { text: "基本设置"; color: #111827; font-size: 16px; font-weight: 700; }
                    LineEdit { placeholder-text: "文件夹 ID，例如 photos"; text <=> root.folder_id; enabled: !root.edit_folder_dialog; }
                    LineEdit { placeholder-text: "显示名称，例如 照片同步"; text <=> root.folder_label; }
                    LineEdit { placeholder-text: "本地路径，例如 /home/user/Pictures"; text <=> root.folder_path; enabled: !root.edit_folder_dialog; }

                    Text { text: "文件夹类型"; color: #64748b; font-size: 13px; }
                    HorizontalLayout {
                        spacing: 8px;
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "双向同步";
                            selected: root.folder_type == "sendreceive";
                            clicked => { root.folder_type = "sendreceive"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "仅发送";
                            selected: root.folder_type == "sendonly";
                            clicked => { root.folder_type = "sendonly"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "仅接收";
                            selected: root.folder_type == "receiveonly";
                            clicked => { root.folder_type = "receiveonly"; }
                        }
                    }

                    Divider { }
                    Text { text: "高级设置"; color: #111827; font-size: 16px; font-weight: 700; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "扫描间隔（秒）"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        LineEdit {
                            width: 100px;
                            text: root.folder_rescan_interval;
                            edited(text) => { root.folder_rescan_interval = text.to-float() >= 0 ? text.to-float() : 3600; }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "文件系统监视"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.folder_fs_watcher ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.folder_fs_watcher ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.folder_fs_watcher = !root.folder_fs_watcher; } }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "忽略权限"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.folder_ignore_perms ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.folder_ignore_perms ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.folder_ignore_perms = !root.folder_ignore_perms; } }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "忽略删除"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.folder_ignore_delete ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.folder_ignore_delete ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.folder_ignore_delete = !root.folder_ignore_delete; } }
                        }
                    }

                    Text { text: "文件版本控制"; color: #64748b; font-size: 13px; }
                    HorizontalLayout {
                        spacing: 8px;
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "不使用";
                            selected: root.folder_versioning_type == "none";
                            clicked => { root.folder_versioning_type = "none"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "简单";
                            selected: root.folder_versioning_type == "simple";
                            clicked => { root.folder_versioning_type = "simple"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "分级";
                            selected: root.folder_versioning_type == "staggered";
                            clicked => { root.folder_versioning_type = "staggered"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "回收站";
                            selected: root.folder_versioning_type == "trashcan";
                            clicked => { root.folder_versioning_type = "trashcan"; }
                        }
                    }

                    Divider { }
                    Text { text: "共享设备"; color: #111827; font-size: 16px; font-weight: 700; }
                    Text { text: "共享设备 ID（逗号分隔）"; color: #64748b; font-size: 12px; }
                    LineEdit { placeholder-text: "留空则仅添加本机"; text <=> root.folder_devices; }
                    Text { text: root.device_choices == "" ? "暂无远程设备。" : "可选设备：" + root.device_choices; color: #94a3b8; font-size: 12px; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Rectangle { }
                FlatButton {
                    width: 72px;
                    text: "取消";
                    clicked => {
                        root.add_folder_dialog = false;
                        root.edit_folder_dialog = false;
                    }
                }
                FlatButton {
                    width: 72px;
                    primary: true;
                    text: root.edit_folder_dialog ? "保存" : "添加";
                    enabled: !root.is_mutating;
                    clicked => {
                        if root.edit_folder_dialog {
                            root.edit_folder_requested(root.folder_id, root.folder_label, root.folder_path, root.folder_devices, root.folder_type, root.folder_rescan_interval, root.folder_fs_watcher, root.folder_ignore_perms, root.folder_ignore_delete, root.folder_versioning_type);
                        } else {
                            root.add_folder_requested(root.folder_id, root.folder_label, root.folder_path, root.folder_devices, root.folder_type, root.folder_rescan_interval, root.folder_fs_watcher, root.folder_ignore_perms, root.folder_ignore_delete, root.folder_versioning_type);
                        }
                        root.add_folder_dialog = false;
                        root.edit_folder_dialog = false;
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.add_device_dialog || root.edit_device_dialog;
        x: (root.width - 580px) / 2;
        y: 60px;
        width: 580px;
        height: 620px;
        background: #ffffff;
        border-radius: 12px;
        opacity: root.add_device_dialog || root.edit_device_dialog ? 1.0 : 0.0;

        animate opacity { duration: 200ms; easing: ease-out; }
        animate y { duration: 250ms; easing: ease-out; }

        VerticalLayout {
            padding: 22px;
            spacing: 12px;
            Text { text: root.edit_device_dialog ? "编辑远程设备" : "添加远程设备"; color: #111827; font-size: 21px; font-weight: 800; }

            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    padding-right: 12px;
                    spacing: 12px;

                    Text { text: "基本设置"; color: #111827; font-size: 16px; font-weight: 700; }
                    LineEdit { placeholder-text: "设备 ID"; text <=> root.device_id; enabled: !root.edit_device_dialog; }
                    LineEdit { placeholder-text: "设备名称，例如 NAS / Laptop"; text <=> root.device_name; }
                    Text { text: "地址（dynamic 或 tcp://host:22000，逗号分隔）"; color: #64748b; font-size: 12px; }
                    LineEdit { text <=> root.device_addresses; }

                    Divider { }
                    Text { text: "高级设置"; color: #111827; font-size: 16px; font-weight: 700; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "引入者"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.device_introducer ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.device_introducer ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.device_introducer = !root.device_introducer; } }
                        }
                    }
                    Text { text: "该设备可以引入其他设备到集群"; color: #94a3b8; font-size: 11px; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "自动接受文件夹"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.device_auto_accept_folders ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.device_auto_accept_folders ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.device_auto_accept_folders = !root.device_auto_accept_folders; } }
                        }
                    }
                    Text { text: "自动接受此设备共享的新文件夹"; color: #94a3b8; font-size: 11px; }

                    Text { text: "压缩方式"; color: #64748b; font-size: 13px; }
                    HorizontalLayout {
                        spacing: 8px;
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "全部压缩";
                            selected: root.device_compression == "always";
                            clicked => { root.device_compression = "always"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "仅元数据";
                            selected: root.device_compression == "metadata";
                            clicked => { root.device_compression = "metadata"; }
                        }
                        OptionButton {
                            horizontal-stretch: 1;
                            text: "不压缩";
                            selected: root.device_compression == "never";
                            clicked => { root.device_compression = "never"; }
                        }
                    }

                    Divider { }
                    Text { text: "共享文件夹"; color: #111827; font-size: 16px; font-weight: 700; }
                    Text { text: "共享文件夹 ID（逗号分隔）"; color: #64748b; font-size: 12px; }
                    LineEdit { placeholder-text: "留空则暂不共享"; text <=> root.device_folders; }
                    Text { text: root.folder_choices == "" ? "暂无同步文件夹。" : "可选文件夹：" + root.folder_choices; color: #94a3b8; font-size: 12px; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Rectangle { }
                FlatButton {
                    width: 72px;
                    text: "取消";
                    clicked => {
                        root.add_device_dialog = false;
                        root.edit_device_dialog = false;
                    }
                }
                FlatButton {
                    width: 72px;
                    primary: true;
                    text: root.edit_device_dialog ? "保存" : "添加";
                    enabled: !root.is_mutating;
                    clicked => {
                        if root.edit_device_dialog {
                            root.edit_device_requested(root.device_id, root.device_name, root.device_addresses, root.device_folders, root.device_introducer, root.device_auto_accept_folders, root.device_compression);
                        } else {
                            root.add_device_requested(root.device_id, root.device_name, root.device_addresses, root.device_folders, root.device_introducer, root.device_auto_accept_folders, root.device_compression);
                        }
                        root.add_device_dialog = false;
                        root.edit_device_dialog = false;
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.ignores_dialog;
        x: (root.width - 500px) / 2;
        y: 112px;
        width: 500px;
        height: 400px;
        background: #ffffff;
        border-radius: 12px;
        opacity: root.ignores_dialog ? 1.0 : 0.0;

        animate opacity { duration: 200ms; easing: ease-out; }
        animate y { duration: 250ms; easing: ease-out; }

        VerticalLayout {
            padding: 22px;
            spacing: 12px;
            Text { text: "编辑忽略模式 (.stignore)"; color: #111827; font-size: 21px; font-weight: 800; }
            Text { text: "每行一个模式，例如 node_modules 或 *.tmp"; color: #64748b; font-size: 13px; }
            Rectangle {
                vertical-stretch: 1;
                border-radius: 8px;
                border-width: 1px;
                border-color: #cbd5e1;
                background: #f8fafc;
                VerticalLayout {
                    padding: 8px;
                    TextInput {
                        text <=> root.ignores_text;
                        wrap: word-wrap;
                    }
                }
            }
            HorizontalLayout {
                spacing: 10px;
                Rectangle { }
                FlatButton {
                    width: 72px;
                    text: "取消";
                    clicked => {
                        root.ignores_dialog = false;
                    }
                }
                FlatButton {
                    width: 72px;
                    primary: true;
                    text: "保存";
                    enabled: !root.is_mutating;
                    clicked => {
                        root.set_folder_ignores_requested(root.ignores_folder_id, root.ignores_text);
                        root.ignores_dialog = false;
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.global_settings_dialog;
        x: (root.width - 580px) / 2;
        y: 60px;
        width: 580px;
        height: 560px;
        background: #ffffff;
        border-radius: 12px;
        opacity: root.global_settings_dialog ? 1.0 : 0.0;

        animate opacity { duration: 200ms; easing: ease-out; }
        animate y { duration: 250ms; easing: ease-out; }

        VerticalLayout {
            padding: 22px;
            spacing: 12px;
            Text { text: "全局高级设置"; color: #111827; font-size: 21px; font-weight: 800; }

            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    padding-right: 12px;
                    spacing: 14px;

                    Text { text: "设备发现"; color: #111827; font-size: 16px; font-weight: 700; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "全局发现"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.global_discovery_enabled ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.global_discovery_enabled ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.global_discovery_enabled = !root.global_discovery_enabled; } }
                        }
                    }
                    Text { text: "使用全局发现服务器查找其他设备"; color: #94a3b8; font-size: 11px; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "本地发现"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.local_discovery_enabled ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.local_discovery_enabled ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.local_discovery_enabled = !root.local_discovery_enabled; } }
                        }
                    }
                    Text { text: "在本地网络中广播以发现设备"; color: #94a3b8; font-size: 11px; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "全局通告"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.global_announce_enabled ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.global_announce_enabled ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.global_announce_enabled = !root.global_announce_enabled; } }
                        }
                    }
                    Text { text: "向全局发现服务器通告此设备"; color: #94a3b8; font-size: 11px; }

                    Divider { }
                    Text { text: "连接设置"; color: #111827; font-size: 16px; font-weight: 700; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "启用 NAT 穿透"; color: #64748b; font-size: 13px; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Rectangle {
                            width: 44px; height: 24px; border-radius: 12px;
                            background: root.nat_enabled ? #2563eb : #cbd5e1;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 10px;
                                background: #ffffff;
                                x: root.nat_enabled ? 22px : 2px;
                                y: 2px;
                                animate x { duration: 200ms; easing: ease-in-out; }
                            }
                            TouchArea { clicked => { root.nat_enabled = !root.nat_enabled; } }
                        }
                    }
                    Text { text: "使用 STUN 和其他技术穿透 NAT"; color: #94a3b8; font-size: 11px; }

                    Text { text: "重连间隔（秒）"; color: #64748b; font-size: 13px; }
                    LineEdit {
                        text: root.reconnection_interval;
                        input-type: number;
                        placeholder-text: "60";
                    }
                    Text { text: "尝试重新连接断开设备的间隔"; color: #94a3b8; font-size: 11px; }

                    Text { text: "最大连接数（0 表示无限制）"; color: #64748b; font-size: 13px; }
                    LineEdit {
                        text: root.max_connections;
                        input-type: number;
                        placeholder-text: "0";
                    }
                    Text { text: "同时连接的最大设备数量"; color: #94a3b8; font-size: 11px; }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                Rectangle { }
                FlatButton {
                    width: 72px;
                    text: "取消";
                    clicked => {
                        root.global_settings_dialog = false;
                    }
                }
                FlatButton {
                    width: 72px;
                    primary: true;
                    text: "保存";
                    enabled: !root.is_mutating;
                    clicked => {
                        root.save_global_settings_requested();
                        root.global_settings_dialog = false;
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.confirm_dialog;
        x: (root.width - 440px) / 2;
        y: 180px;
        width: 440px;
        height: 230px;
        background: #ffffff;
        border-radius: 12px;
        opacity: root.confirm_dialog ? 1.0 : 0.0;

        animate opacity { duration: 200ms; easing: ease-out; }
        animate y { duration: 250ms; easing: ease-out; }

        VerticalLayout {
            padding: 22px;
            spacing: 14px;
            Text { text: root.confirm_title; color: #111827; font-size: 21px; font-weight: 800; }
            Text { text: root.confirm_message; color: #334155; font-size: 14px; }
            Text { text: root.confirm_target; color: #64748b; font-size: 12px; }
            HorizontalLayout {
                spacing: 10px;
                Rectangle { }
                FlatButton {
                    width: 72px;
                    text: "取消";
                    clicked => {
                        root.confirm_dialog = false;
                    }
                }
                FlatButton {
                    width: 72px;
                    danger: true;
                    text: "确认";
                    enabled: !root.is_mutating;
                    clicked => {
                        root.confirmed_action_requested(root.confirm_action, root.confirm_target);
                        root.confirm_dialog = false;
                    }
                }
            }
        }
    }
}
